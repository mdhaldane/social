<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default: "Matt Haldane | Social Dashboard" }}</title>
  <meta name="description" content="{{ description | default: 'Centralized microblog and social dashboard for Matt Haldane, aggregating posts from Bluesky, Mastodon, and local notes.' }}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">
  <header class="masthead">
    <div class="masthead-inner">
      <a href="https://matthaldane.com" class="site-title">Matt Haldane</a>
      <span class="site-subtitle">/ social</span>
    </div>
  </header>

  <main id="main-content">
    {{ content }}
  </main>

  <footer class="footer">
    <p>Return to <a href="https://matthaldane.com">matthaldane.com</a></p>
  </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/medium-zoom@1.1.0/dist/medium-zoom.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    mediumZoom('[data-zoomable]', {
      background: '#000000',
      margin: 24
    });
  });
</script>

</body>
</html>
