---
layout: base.liquid
title: "Matt Haldane | Social Feed"
description: "A centralized social timeline aggregating posts from Bluesky, Mastodon, and local IndieWeb notes."
---

<div class="profile-header">
  <div class="profile-banner">
    <img src="/images/banner.jpg" alt="Profile Banner" />
  </div>
  <div class="profile-info-container">
    <div class="profile-avatar-wrapper">
      <img class="profile-avatar" src="/images/avatar.png" alt="Matt Haldane" />
    </div>
    <div class="profile-details">
      <div class="profile-name-group">
        <h1 class="profile-display-name">Matt Haldane</h1>
      </div>
      <p class="profile-bio">At a glance I can distinguish China from Arizona</p>
      <div class="profile-meta-links">
        <span class="profile-meta-item">
          <svg class="icon" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          <a href="https://matthaldane.com" target="_blank" rel="noopener noreferrer">matthaldane.com</a>
        </span>
        <span class="profile-meta-item">
          <svg class="icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a4 4 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522q0-1.288.66-2.046c.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764q.662.757.661 2.046z"/></svg>
          <a href="https://mastodon.social/@mdhaldane" target="_blank" rel="noopener noreferrer">Mastodon</a>
        </span>
        <span class="profile-meta-item">
          <svg class="icon" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M3.468 1.948C5.303 3.325 7.276 6.118 8 7.616c.725-1.498 2.698-4.29 4.532-5.668C13.855.955 16 .186 16 2.632c0 .489-.28 4.105-.444 4.692-.572 2.04-2.653 2.561-4.504 2.246 3.236.551 4.06 2.375 2.281 4.2-3.376 3.464-4.852-.87-5.23-1.98-.07-.204-.103-.3-.103-.218 0-.081-.033.014-.102.218-.379 1.11-1.855 5.444-5.231 1.98-1.778-1.825-.955-3.65 2.28-4.2-1.85.315-3.932-.205-4.503-2.246C.28 6.737 0 3.12 0 2.632 0 .186 2.145.955 3.468 1.948z"/></svg>
          <a href="https://bsky.app/profile/social.matthaldane.com" target="_blank" rel="noopener noreferrer">Bluesky</a>
        </span>
      </div>
    </div>
  </div>
</div>

<div class="feed-container">
  {% for item in collections.unifiedFeed %}
    <article class="post-item">
      <header class="post-meta">
        <span class="post-source">
          {% if item.type == 'local' %}
            local
          {% else %}
            {{ item.source }}
          {% endif %}
        </span>
        <span class="post-date">
          <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">
            <time class="local-date" datetime="{{ item.date | dateToISO }}">{{ item.date | dateToISO }}</time>
          </a>
        </span>
      </header>

      <div class="post-content">{{ item.content }}</div>

      {% if item.external %}
        {% assign ext_url_lower = item.external.uri | downcase %}
        {% unless ext_url_lower contains "youtube.com" or ext_url_lower contains "youtu.be" %}
          <a href="{{ item.external.uri }}" target="_blank" rel="noopener noreferrer" class="external-card">
            {% if item.external.thumb %}
              <div class="external-thumb">
                <img src="{{ item.external.thumb }}" alt="{{ item.external.title }}" loading="lazy" />
              </div>
            {% endif %}
            <div class="external-info">
              <h4 class="external-title">{{ item.external.title | default: "Link" }}</h4>
              {% if item.external.description %}
                <p class="external-description">{{ item.external.description }}</p>
              {% endif %}
              <span class="external-url">{{ item.external.uri }}</span>
            </div>
          </a>
        {% endunless %}
      {% endif %}

      {% if item.images and item.images.size > 0 %}
        <div class="post-media-grid" data-count="{{ item.images.size }}">
          {% for img in item.images %}
            <img src="{{ img.url }}" alt="{{ img.alt }}" loading="lazy" data-zoomable />
          {% endfor %}
        </div>
      {% endif %}

      {% if item.interactions %}
        {% assign has_likes = item.interactions.likes | default: 0 %}
        {% assign has_reposts = item.interactions.reposts | default: 0 %}
        {% assign has_replies = item.interactions.replies | default: 0 %}
        {% if has_likes > 0 or has_reposts > 0 or has_replies > 0 %}
          <div class="post-interactions" style="margin-top: 15px; font-size: 0.8rem; color: #8c8578; display: flex; gap: 16px; border-top: 1px dashed #1c1c24; padding-top: 10px;">
            {% if has_likes > 0 %}
              <span class="interaction-item" title="Likes">★ {{ has_likes }}</span>
            {% endif %}
            {% if has_reposts > 0 %}
              <span class="interaction-item" title="Reposts">⇄ {{ has_reposts }}</span>
            {% endif %}
            {% if has_replies > 0 %}
              <span class="interaction-item" title="Replies">💬 {{ has_replies }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </article>
  {% else %}
    <p style="text-align: center; color: #8c8578; padding: 40px 0;">
      No posts found in the feed. Run the prebuild script to fetch remote posts.
    </p>
  {% endfor %}
</div>
